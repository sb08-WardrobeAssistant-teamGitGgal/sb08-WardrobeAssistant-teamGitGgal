{
  "analysis": {
    "analyzer": {
      "nori_custom": {
        "type": "custom",
        "tokenizer": "nori_tokenizer",
        "filter": ["nori_posfilter"]
      }
    },
    "filter": {
      "nori_posfilter": {
        "type": "nori_part_of_speech",
        "stoptags": [
          "E", "IC", "J", "MAJ", "MM",
          "SP", "SSC", "SSO", "SC", "SE",
          "XPN", "XSA", "XSN", "XSV",
          "UNA", "NA"
        ]
      }
    }
  }
}